{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex App Plus",
  "version": "0.1.0",
  "identifier": "com.codex.app.plus",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex App Plus",
        "width": 1680,
        "height": 1024,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "nsis"
  }
}
